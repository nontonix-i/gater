# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Seed: global API key for the default user
SEED_API_KEY=gater-key-001

# Seed: provider credentials (one var per provider, key=value pairs comma-separated)
SEED_ANONMP4=
SEED_ABYSS=api_key=your_abyss_api_key
SEED_DOODSTREAM=api_key=your_doodstream_key,folder_id=optional_folder_id
SEED_GOFILE=token=your_gofile_token,folder_id=optional_folder_id
SEED_LULUSTREAM=api_key=your_lulustream_key
SEED_RAPIDGATOR=username=your_username,password=your_password
SEED_RPMSHARE=api_token=your_rpmshare_token
SEED_SEEKSTREAMING=api_token=your_seekstreaming_token
SEED_STREAMTAPE=login=your_streamtape_login,key=your_streamtape_key
SEED_TURBOVIPLAY=api_key=your_turboviplay_key
SEED_VIDOZA=api_token=your_vidoza_token
SEED_VIKINGFILES=user=your_vikingfiles_user_id
